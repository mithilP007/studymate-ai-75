{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!assets/|api/|_vinxi/).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/((?!assets/).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
