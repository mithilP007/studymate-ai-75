{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "noEmit": false,
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "vite.config.ts"
  ]
}